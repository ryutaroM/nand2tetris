// File name: projects/1/Mux.hdl
/**
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Or(a=a, b=sel, out=t);
    Not(in= sel, out= notSel);
    Or (a= b, b= notSel, out=f);
    And(a=t, b= f, out= out);
}